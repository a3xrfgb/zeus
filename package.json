    "heic2any": "^0.0.4",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.1",
    "javascript-time-ago": "^2.6.4",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lodash": "^4.18.1",
    "lucide-react": "^0.487.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "motion": "^12.39.0",
    "music-metadata": "^11.13.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.10.38",
    "radix-ui": "^1.4.3",
    "rc-field-form": "^2.7.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-drag-listview": "^2.0.0",
    "react-full-screen": "^1.1.1",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-infinite-scroll-component": "^7.2.1",
    "react-markdown": "^10.1.0",
    "react-player-controls": "^1.1.0",
    "react-redux": "^9.3.0",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.17.0",
    "react-time-ago": "^7.4.4",
    "redux-persist": "^6.0.0",
    "redux-persist-expire": "^1.1.1",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.0.2",
    "tinycolor2": "^1.6.0",
    "tokenlens": "^1.3.1",
    "use-debounce": "^10.1.1",
    "use-stick-to-bottom": "^1.1.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/spotify-web-playback-sdk": "^0.1.19",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.3",
    "rcedit": "^4.0.1",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "ai.zeus.app",
    "productName": "Zeus",
    "executableName": "Zeus",
    "icon": "icon.ico",
    "directories": {
      "output": "release",
      "buildResources": "core/icons"
    },
    "files": [
      "out/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "core/icons/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "core/target/release",
        "to": ".",
        "filter": [
          "zeus-sidecar.exe",
          "zeus-sidecar"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
