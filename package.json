{
  "name": "zeus-electron",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/ensure-sidecar.mjs && electron-vite dev",
    "sync:public": "node scripts/sync-public-assets.mjs",
    "build": "node scripts/sync-public-assets.mjs && electron-vite build && node scripts/verify-public-assets.mjs",
    "preview": "electron-vite preview",
    "build:sidecar": "cargo build --release --manifest-path core/Cargo.toml --bin zeus-sidecar",
    "build:sidecar:dev": "cargo build --manifest-path core/Cargo.toml --bin zeus-sidecar",
    "build:all": "npm run build:sidecar && npm run build",
    "pack": "npm run build:all && electron-builder && node scripts/embed-win-icon.mjs",
    "pack:win": "node scripts/pre-pack-win.mjs && npm run build:all && electron-builder --win --config.directories.output=dist/pack-staging && node scripts/post-pack-win.mjs && node scripts/embed-win-icon.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
